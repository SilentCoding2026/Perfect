// "The Signal" v2 — Rig-based character animation demo
// Smoother movement, procedural walk cycles, pose interpolation

import character maya from "assets/characters/maya_rig"
import character viktor from "assets/characters/viktor_rig"
import character kai from "assets/characters/kai_rig"
import set server-room from "assets/sets/server-room.svg"
import set rooftop from "assets/sets/rooftop.svg"

config {
    width: 1280
    height: 720
    fps: 30
    background: #0a0a12
}

// --- SCENE 1: Server Room Discovery (10s) ---
scene "discovery" (duration: 10s, set: server-room) {
    place kai at center facing right

    camera close-up kai
    wait 1.2s

    camera medium kai
    wait 0.6s

    kai pose "excited"
    wait 0.4s

    maya enters left over 1.4s ease-out
    camera wide
    wait 0.3s

    maya moves-to left-third over 1.2s ease-in-out
    camera two-shot
    wait 0.4s

    kai pose "excited"
    wait 0.6s

    maya pose "thinking"
    wait 1s

    maya pose "surprised"
    camera close-up maya
    wait 1.2s

    camera close-up kai
    kai pose "scared"
    wait 1s

    transition fade-black 0.8s
}

// --- SCENE 2: Rooftop Confrontation (16s) ---
scene "confrontation" (duration: 16s, set: rooftop) {
    place maya at left-third facing right
    place kai at left facing right

    camera wide
    wait 0.6s

    maya pose "thinking"
    wait 1.2s

    viktor enters right over 1.8s ease-out
    camera wide
    wait 0.4s

    viktor pose "menacing"
    camera zoom-to viktor over 1.8s ease-in-out
    wait 0.6s

    camera close-up maya
    maya pose "idle"
    wait 1s

    camera wide
    wait 0.4s

    viktor moves-to center over 1.5s ease-in
    wait 0.3s

    together {
        kai pose "scared"
        kai moves-to left-edge over 1s ease-out
    }
    wait 0.4s

    maya pose "pointing"
    camera close-up maya
    wait 1.2s

    camera close-up viktor
    viktor pose "angry"
    wait 1s

    camera wide
    wait 0.6s

    camera shake 0.5s intensity 8

    viktor pose "surprised"
    wait 0.6s

    together {
        maya moves-to right-third over 0.8s ease-in
        kai moves-to center over 1s ease-out
    }
    wait 0.4s

    transition fade-black 1s
}

// --- SCENE 3: The Escape (10s) ---
scene "escape" (duration: 10s, set: rooftop) {
    place maya at center facing right
    place kai at left-third facing right

    camera wide
    wait 0.4s

    together {
        maya moves-to right-edge over 2s ease-in
        kai moves-to right-third over 2s ease-in
        camera pan-to (0.7, 0.5) over 2s ease-in-out
    }

    wait 0.3s

    kai moves-to right-edge over 1s ease-in
    wait 0.3s

    together {
        maya exits right over 0.8s ease-in
        kai exits right over 1s ease-in
    }

    camera wide
    wait 1.2s

    viktor enters left over 2.5s ease-out
    viktor pose "idle"
    camera zoom-to viktor over 2s ease-in-out
    wait 0.8s

    transition fade-black 1.5s
}
